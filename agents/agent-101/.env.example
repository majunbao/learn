# API Configuration
# API 配置

# API Key for accessing the API service
# 访问 API 服务的密钥
#
# 填写你使用的 API 服务的 Key
#
ARK_API_KEY=your-api-key-here

# API Base URL
# API 基础地址
#
# OpenAI 示例：https://api.openai.com/v1
# 其他兼容 OpenAI API 的服务：填写对应服务的 URL
#
ARK_API_BASE=https://your-api-base-url/v1

# Model to use
# 使用的模型名称
#
# OpenAI 示例：gpt-4o, gpt-3.5-turbo
# 其他服务：填写对应模型名称
#
MODEL=your-model-name

# Optional: Search API Configuration (for WebSearchTool)
# 可选：搜索 API 配置（用于 WebSearchTool）
SEARCH_API_URL=https://open.feedcoopapi.com/search_api/web_search
SEARCH_API_KEY=your-search-api-key-here
